# Kopiere diese Datei nach .env und passe die Werte an.

# Postgres-Passwort (wird für alle DB-User verwendet)
POSTGRES_PASSWORD=portalpass

# JWT Secret – UNBEDINGT für Produktion ändern!
# Generieren mit: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Öffentliche URL der Site (ohne Trailing-Slash)
SITE_URL=http://localhost

# n8n Webhook-URL für Formular-Einreichungen
N8N_WEBHOOK_URL=https://n8n.agentsmithery.de/webhook/...
